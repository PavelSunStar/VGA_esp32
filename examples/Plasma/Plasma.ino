void init_sin(){
  word i;
  float v;

  for(int i = 0; i < 256; ++i){
    v = (float)(sin(2.0 * 3.14 * i / 255.0) + 1.0 ) / 2.0;
    SIN256[i] = (uint8_t)(255 * v);
  }
}

void init_pal(){
  for (int i = 0; i < 256; i++){
    uint16_t r = PAL[i * 3 + 2] << 2; if (r > 255) r = 255;
    uint16_t g = 256 - (PAL[i * 3] << 2); if (g > 255) g = 255;
    uint16_t b = 256 - (PAL[i * 3 + 1] << 2); //if (b > 255) b = 255;
    palette[i] = gfx.getColor(r, g, b);
  }
}

void draw_plasma(uint16_t x, uint16_t y, uint16_t w, uint16_t h, uint16_t t){
  uint16_t c;
  uint16_t c1, c2, c3;
  uint16_t v1,v2;
  int tt, ttt;
  uint16_t jv2;

  tt = (uint8_t)t * 2;
  ttt = (uint8_t)t * 3;
  v1 = SIN256[(uint8_t)tt];
  v2 = SIN256[(uint8_t)(t)];
  
  for(int j = y; j < y + h; j++){
    c3 = SIN256[(uint8_t)(j * 3 + ttt)];
    jv2 = j * v2 / h + t;
    for(int i = x; i < x + w; i++) {
      c1 = SIN256[(uint8_t) (i * 3 + tt)];
      c2 = SIN256[(uint8_t)((i * v1) / w + jv2)];
      c = (uint8_t)((c1 + c2 + c3) / 3);

      gfx.putPixel(i, j, palette[c]);
    }
  }
}

void setup() {
  vga.init(MODE640x480_60Hz, 16, 2, true);
  init_pal();
  init_sin();
}

void loop() {
  draw_plasma(0, 0, vga.Width(), vga.Height(), t);

  vga.swap();
  t++;
}
